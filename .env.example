# ── Admin initial (seed DB) ────────────────────────────────────────
# Si la table `users` est vide au démarrage, un compte admin est créé avec ces identifiants.
# Ensuite la gestion des comptes se fait dans l’app (menu Comptes, réservé admin).
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Secret de signature des cookies de session (obligatoire en prod)
SESSION_SECRET=change-me-to-a-long-random-string

# Compat : anciennes variables encore lues si ADMIN_* absentes
# AUTH_USER=admin
# AUTH_PASS=changeme

# Server
PORT=3001

# ── Base MySQL (optionnel — sinon SQLite sous DATA_DIR) ───────────
# Si DATABASE_URL est défini, OU si MYSQL_HOST + MYSQL_USER + MYSQL_PASSWORD + MYSQL_DATABASE le sont,
# le backend utilise mysql2 au lieu de better-sqlite3.
# Exemple Hostinger / PlanetScale style :
# DATABASE_URL=mysql://user:password@host:3306/nom_base
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=
# MYSQL_PASSWORD=
# MYSQL_DATABASE=

# ── Persistance des données (production) ─────────────────────────
# SQLite + uploads sont stockés sous ce dossier (défaut : backend/data).
# Sur un hébergeur où chaque déploiement repart d’un disque vierge, sans volume
# persistant la base est RECRÉÉE VIDE à chaque fois. Monter un disque ou définir :
# DATA_DIR=/chemin/absolu/vers/un/dossier/persistant
# (même chemin entre les déploiements, hors du build éphémère).
