# ── Admin initial (seed DB) ────────────────────────────────────────
# Si la table `users` est vide au démarrage, un compte admin est créé avec ces identifiants.
# Ensuite la gestion des comptes se fait dans l’app (menu Comptes, réservé admin).
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Secret de signature des cookies de session (obligatoire en prod)
SESSION_SECRET=change-me-to-a-long-random-string

# Compat : anciennes variables encore lues si ADMIN_* absentes
# AUTH_USER=admin
# AUTH_PASS=changeme

# Server
PORT=3001
# DEBUG global backend (HTTP + erreurs + DB)
# BACKEND_DEBUG=1
# Ou séparément :
# DEBUG_HTTP=1
# DEBUG_ERRORS=1
# DB_DEBUG=1

# ── Base MySQL (optionnel — sinon SQLite sous DATA_DIR) ───────────
# Si ces variables sont définies, TOUTES les données (y compris médias BLOB) vont
# sur cette base, que tu lances le backend en local ou sur Hostinger.
# Exemple Hostinger :
# DATABASE_URL=mysql://user:password@host:3306/nom_base
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=
# MYSQL_PASSWORD=
# MYSQL_DATABASE=

# ── Persistance des données (production) ─────────────────────────
# Dossier RACINE pour SQLite local, seeds et cache disque uploads/.
# Les binaires média sont stockés en BLOB (media.content) — source de vérité en prod MySQL.
# Relatif au dossier backend/ si chemin non absolu. Défaut si absent : backend/data
# DATA_DIR=data
# DATA_DIR=/var/lib/card-designer/data
