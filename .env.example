# ── Admin initial (seed DB) ────────────────────────────────────────
# Si la table `users` est vide au démarrage, un compte admin est créé avec ces identifiants.
# Ensuite la gestion des comptes se fait dans l’app (menu Comptes, réservé admin).
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Secret de signature des cookies de session (obligatoire en prod)
SESSION_SECRET=change-me-to-a-long-random-string

# Compat : anciennes variables encore lues si ADMIN_* absentes
# AUTH_USER=admin
# AUTH_PASS=changeme

# Server
PORT=3001
